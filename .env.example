# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/sweetcms

# Auth
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=SweetCMS
NODE_ENV=development
PORT=3000

# Server role: all | frontend | api | worker
SERVER_ROLE=all

# Redis (optional — required for BullMQ)
# REDIS_URL=redis://localhost:6379

# Email (SMTP — optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# FROM_EMAIL=noreply@example.com

# Storage
STORAGE_BACKEND=filesystem
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# NEXT_PUBLIC_CDN_URL=

# Social login (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
